{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adhd.local/schemas/job.schema.json",
  "title": "JobRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jobId",
    "hostId",
    "inputText",
    "state",
    "delegationMode",
    "policySnapshot",
    "timestamps"
  ],
  "properties": {
    "jobId": {
      "type": "string",
      "pattern": "^j_[a-z0-9]{6,}$"
    },
    "hostId": {
      "type": "string",
      "pattern": "^h_[a-z0-9]{6,}$"
    },
    "hostJobId": {
      "type": ["string", "null"]
    },
    "inputText": {
      "type": "string",
      "minLength": 1
    },
    "threadId": {
      "type": ["string", "null"]
    },
    "turnId": {
      "type": ["string", "null"]
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "dispatching",
        "planning",
        "awaiting_approval",
        "delegating",
        "running",
        "summarizing",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "delegationMode": {
      "type": "string",
      "enum": ["multi_agent", "fallback_workers"]
    },
    "intake": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["mode", "source", "language", "segmentCount"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["voice", "text"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": ["string", "null"]
        },
        "segmentCount": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "intent": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "./intent.schema.json"
        }
      ]
    },
    "plan": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "./plan.schema.json"
        }
      ]
    },
    "delegationDecision": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requestedMode",
            "selectedMode",
            "reasonCode",
            "reason",
            "killSwitchApplied",
            "policy",
            "hostCapability"
          ],
          "properties": {
            "requestedMode": {
              "type": "string",
              "enum": ["multi_agent", "fallback_workers"]
            },
            "selectedMode": {
              "type": "string",
              "enum": ["multi_agent", "fallback_workers"]
            },
            "reasonCode": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "killSwitchApplied": {
              "type": "boolean"
            },
            "policy": {
              "type": "object",
              "additionalProperties": true,
              "required": ["defaultMode", "allowMultiAgent", "multiAgentKillSwitch"],
              "properties": {
                "defaultMode": {
                  "type": "string",
                  "enum": ["multi_agent", "fallback_workers"]
                },
                "allowMultiAgent": {
                  "type": "boolean"
                },
                "multiAgentKillSwitch": {
                  "type": "boolean"
                }
              }
            },
            "hostCapability": {
              "type": "object",
              "additionalProperties": true,
              "required": ["multiAgent"],
              "properties": {
                "multiAgent": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      ]
    },
    "policySnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approvalPolicy", "sandboxPolicy", "maxWorkers", "timeoutMs"],
      "properties": {
        "approvalPolicy": { "type": "string" },
        "sandboxPolicy": { "type": "string" },
        "maxWorkers": { "type": "integer", "minimum": 1 },
        "timeoutMs": { "type": "integer", "minimum": 1 }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["createdAt", "updatedAt"],
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "endedAt": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "resultSummary": {
      "type": ["string", "null"]
    },
    "artifactPaths": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
