{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adhd.local/schemas/plan.schema.json",
  "title": "ExecutionPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "intentContractVersion",
    "promptVersion",
    "summary",
    "workType",
    "target",
    "paths",
    "constraints",
    "hostConstraints",
    "steps",
    "delegation",
    "metadata"
  ],
  "properties": {
    "contractVersion": {
      "type": "string",
      "const": "plan.v1"
    },
    "intentContractVersion": {
      "type": "string",
      "const": "intent.v1"
    },
    "promptVersion": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "workType": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hostConstraints": {
      "type": ["object", "null"]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "acceptanceCriteria", "risk"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "acceptanceCriteria": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    },
    "delegation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestedMode",
        "selectedMode",
        "reasonCode",
        "reason",
        "killSwitchApplied",
        "policy",
        "hostCapability"
      ],
      "properties": {
        "requestedMode": {
          "type": "string",
          "enum": ["multi_agent", "fallback_workers"]
        },
        "selectedMode": {
          "type": "string",
          "enum": ["multi_agent", "fallback_workers"]
        },
        "reasonCode": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "killSwitchApplied": {
          "type": "boolean"
        },
        "policy": {
          "type": "object",
          "additionalProperties": true,
          "required": ["defaultMode", "allowMultiAgent", "multiAgentKillSwitch"],
          "properties": {
            "defaultMode": {
              "type": "string",
              "enum": ["multi_agent", "fallback_workers"]
            },
            "allowMultiAgent": {
              "type": "boolean"
            },
            "multiAgentKillSwitch": {
              "type": "boolean"
            }
          }
        },
        "hostCapability": {
          "type": "object",
          "additionalProperties": true,
          "required": ["multiAgent"],
          "properties": {
            "multiAgent": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "metadata": {
      "type": ["object", "null"]
    }
  }
}
